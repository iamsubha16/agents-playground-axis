# LiveKit (NEXT_PUBLIC_LIVEKIT_URL is exposed to the browser by design)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=

# SIP test-call dialer (prefer this; server-only)
SIP_DIALER_API_URL=
# Legacy: still read by API routes only if SIP_DIALER_API_URL is unset (not bundled to client)
# NEXT_PUBLIC_SIP_DIALER_URL=

# Studio API (server-only)
STUDIO_API_URL=
STUDIO_API_KEY=

# Optional: YAML app config (public — embedded in client bundle if set)
# NEXT_PUBLIC_APP_CONFIG=
